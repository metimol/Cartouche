API_BASE_URL=https://fraplat.tech/mars/Cartouche
API_TOKEN=123
GOOGLE_API_KEY=your_google_api_key_here

# Database Configuration
DB_PATH=data/cartouche.db
VECTOR_DB_PATH=data/vector_store

# LLM Configuration
DEFAULT_LLM_MODEL=gemini-pro
LIGHT_LLM_MODEL=gemini-pro
MAX_TOKENS=1024
TEMPERATURE=0.7

# Bot Configuration
INITIAL_BOTS_COUNT=20
DAILY_BOTS_GROWTH_MIN=20
DAILY_BOTS_GROWTH_MAX=50
MAX_BOTS_COUNT=10000

# Monitoring Configuration
MONITORING_INTERVAL=60
REACTION_DELAY_MIN=30
REACTION_DELAY_MAX=300

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/cartouche.log
