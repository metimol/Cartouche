# Example .env file for Cartouche Bot Service
# API Configuration
API_BASE_URL=https://fraplat.tech/mars/Cartouche
API_TOKEN=123

# LLM Configuration
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
DEFAULT_LLM_PROVIDER=gemini
TEMPERATURE=0.7
MAX_TOKENS=1024

# Database Configuration
DB_PATH=data/cartouche.db
VECTOR_DB_PATH=data/vector_store

# Bot Configuration
INITIAL_BOTS_COUNT=20
DAILY_BOTS_GROWTH_MIN=20
DAILY_BOTS_GROWTH_MAX=50
MAX_BOTS_COUNT=5000

# Monitoring Configuration
REACTION_DELAY_MIN=5
REACTION_DELAY_MAX=30

# Logging Configuration
LOG_LEVEL=DEBUG
LOG_FILE=logs/cartouche.log
