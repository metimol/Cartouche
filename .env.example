# =============================================================================
# Cartouche Bot Service - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# Required variables are marked with [REQUIRED]

# =============================================================================
# API Configuration
# =============================================================================
# Base URL for the Cartouche C# API
API_BASE_URL=https://fraplat.tech/mars/Cartouche

# Authentication token for Cartouche API [REQUIRED]
API_TOKEN=your_cartouche_api_token_here

# =============================================================================
# LLM Configuration (At least one API key is required)
# =============================================================================
# Google AI API Key for Gemini models
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-2.0-flash

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Default LLM provider (gemini or openai)
DEFAULT_LLM_PROVIDER=gemini

# LLM Generation Parameters
TEMPERATURE=0.7
MAX_TOKENS=1024

# =============================================================================
# Database Configuration
# =============================================================================
# Path to SQLite database file
DB_PATH=data/database/cartouche.db

# =============================================================================
# Vector Database Configuration (Qdrant)
# =============================================================================
# Qdrant connection (use 'qdrant' for Docker, or external URL)
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# =============================================================================
# Bot Configuration
# =============================================================================
# Initial number of bots to create on startup
INITIAL_BOTS_COUNT=20

# Daily bot growth parameters
DAILY_BOTS_GROWTH_MIN=20
DAILY_BOTS_GROWTH_MAX=50

# Maximum total number of bots
MAX_BOTS_COUNT=5000

# Maximum comments per post
MAX_COMMENTS_PER_POST=3

# =============================================================================
# Content Theme Configuration
# =============================================================================
# Comma-separated list of social network themes
SOCIAL_NETWORK_THEMES=technology,programming,artificial intelligence,science,news,entertainment,sports,politics,memes,personal,random

# Main theme focus description
MAIN_THEME_FOCUS=Everything and anything, just like Twitter

# Theme diversity level (0.0-1.0, where 1.0 is maximum diversity)
THEME_DIVERSITY_LEVEL=0.7

# =============================================================================
# Monitoring Configuration
# =============================================================================
# Reaction delay range in seconds (min, max)
REACTION_DELAY_MIN=5
REACTION_DELAY_MAX=30

# =============================================================================
# Logging Configuration
# =============================================================================
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path
LOG_FILE=data/logs/cartouche.log
